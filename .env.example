# Application
APP_NAME=Payroll Accounting Mapper API
APP_ENV=development        # change to 'production' on the server
APP_DEBUG=true

# PostgreSQL base default (Docker local dev).
# Override per environment:
#   .env.development  → postgresql://payroll:payroll@localhost:5432/payroll_mapper
#   .env.production   → postgresql://<user>:<password>@<host>:<port>/payroll_mapper
DATABASE_URL=postgresql://payroll:payroll@localhost:5432/payroll_mapper